{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": ".",
    "rootDir": ".",
    "strict": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "removeComments": false,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "../../src/plugin-system/schema-types.js": ["../plugin-schema-types.ts"]
    }
  },
  "include": ["*/index.ts", "shared/*.ts"],
  "exclude": ["node_modules"]
}
