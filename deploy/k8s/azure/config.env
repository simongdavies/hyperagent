# Azure Deployment Configuration for HyperAgent
# All resources are created in the same resource group.
# Override any value with environment variables.

# ── Resource Group ────────────────────────────────────────────────────
RESOURCE_GROUP="${RESOURCE_GROUP:-hyperagent-rg}"
LOCATION="${LOCATION:-westus3}"

# ── Azure Container Registry ─────────────────────────────────────────
ACR_NAME="${ACR_NAME:-hyperagentacr}"

# ── AKS Cluster ──────────────────────────────────────────────────────
CLUSTER_NAME="${CLUSTER_NAME:-hyperagent-cluster}"

# ── System node pool ─────────────────────────────────────────────────
SYSTEM_NODE_COUNT="${SYSTEM_NODE_COUNT:-1}"
SYSTEM_NODE_VM_SIZE="${SYSTEM_NODE_VM_SIZE:-Standard_D2s_v3}"

# ── KVM node pool (Ubuntu with nested virtualization) ─────────────────
KVM_NODE_POOL_NAME="${KVM_NODE_POOL_NAME:-kvmpool}"
KVM_NODE_COUNT="${KVM_NODE_COUNT:-1}"
KVM_NODE_VM_SIZE="${KVM_NODE_VM_SIZE:-Standard_D4s_v3}"
KVM_OS_SKU="${KVM_OS_SKU:-Ubuntu}"
KVM_NODE_MIN_COUNT="${KVM_NODE_MIN_COUNT:-1}"
KVM_NODE_MAX_COUNT="${KVM_NODE_MAX_COUNT:-5}"

# ── Device plugin ────────────────────────────────────────────────────
DEVICE_PLUGIN_IMAGE="${DEVICE_PLUGIN_IMAGE:-ghcr.io/hyperlight-dev/hyperlight-device-plugin:latest}"
DEVICE_COUNT="${DEVICE_COUNT:-2000}"
DEVICE_UID="${DEVICE_UID:-65534}"
DEVICE_GID="${DEVICE_GID:-65534}"

# ── HyperAgent image ────────────────────────────────────────────────
HYPERAGENT_IMAGE_NAME="${HYPERAGENT_IMAGE_NAME:-hyperagent}"
HYPERAGENT_IMAGE_TAG="${HYPERAGENT_IMAGE_TAG:-latest}"

# ── Azure subscription (optional — uses current if not set) ──────────
SUBSCRIPTION="${SUBSCRIPTION:-}"
